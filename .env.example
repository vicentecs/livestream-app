# Google OAuth 2.0
# Obter em: console.cloud.google.com → APIs e Serviços → Credenciais
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sessão da aplicação
# Gerar com: python3 -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=

# URL pública via Cloudflare Tunnel (sem barra no final)
# Deve bater exatamente com o URI cadastrado no Google Cloud Console
APP_PUBLIC_URL=https://live.seudominio.com

# Restreamer (não alterar se usando docker-compose padrão)
RESTREAMER_URL=http://restreamer:8080
RESTREAMER_USER=
RESTREAMER_PASS=

# Câmera IP — URL RTSP completa com credenciais
RTSP_URL=rtsp://usuario:senha@192.168.1.XX:554/stream

# Cloudflare Tunnel
# Obter em: dash.cloudflare.com → Zero Trust → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=
