# ============================================================================
# Livestream Orchestrator — template de variáveis de ambiente
# ============================================================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha TODAS as variáveis abaixo (todas são obrigatórias)
# 3. NUNCA commite o .env (já está no .gitignore)
# ============================================================================

# ---------------------------------------------------------------------------
# Google OAuth 2.0
# ---------------------------------------------------------------------------
# Obter em: https://console.cloud.google.com/apis/credentials
# Setup completo: docs/setup-google-cloud.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Sessão da aplicação
# ---------------------------------------------------------------------------
# Chave usada por itsdangerous para assinar cookies de sessão.
# Gerar com: python3 -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=

# ---------------------------------------------------------------------------
# URL pública
# ---------------------------------------------------------------------------
# URL acessível pela internet, via Cloudflare Tunnel.
# - SEM barra no final
# - Deve bater EXATAMENTE com o "URI de redirecionamento autorizado"
#   cadastrado no Google Cloud Console (com /auth/callback ao final lá)
APP_PUBLIC_URL=https://live.seudominio.com

# ---------------------------------------------------------------------------
# Restreamer (datarhei)
# ---------------------------------------------------------------------------
# URL interna acessada pela app via rede do Docker Compose.
# Não alterar a menos que tenha mudado o nome do serviço no compose.
RESTREAMER_URL=http://restreamer:8080

# Credenciais admin do Restreamer — definidas na primeira execução do container.
RESTREAMER_USER=
RESTREAMER_PASS=

# ---------------------------------------------------------------------------
# Câmera IP
# ---------------------------------------------------------------------------
# URL RTSP completa, com credenciais embutidas.
# Deve entregar H.264 (Baseline/Main/High até nível 4.2).
# Validar com: docs/setup-raspberry.md#5--validar-câmera-rtsp-antes-de-subir-a-stack
RTSP_URL=rtsp://usuario:senha@192.168.1.XX:554/stream

# ---------------------------------------------------------------------------
# Cloudflare Tunnel
# ---------------------------------------------------------------------------
# Token do tunnel — obter em:
# https://one.dash.cloudflare.com → Networks → Tunnels → seu tunnel → Token
CLOUDFLARE_TUNNEL_TOKEN=
